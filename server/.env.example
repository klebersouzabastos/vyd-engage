# Database
DATABASE_URL="postgresql://flowcrm:flowcrm_dev_password@localhost:5432/flowcrm"

# JWT Secrets
JWT_SECRET="your-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Logging — pino level: trace|debug|info|warn|error|fatal (default: debug in dev, info in prod)
LOG_LEVEL=""

# Queue dashboard (Bull Board) — Basic-Auth credentials. Both must be set to mount /admin/queues.
QUEUE_DASHBOARD_USER=""
QUEUE_DASHBOARD_PASS=""

# CORS — comma-separated allowed origins in production (REQUIRED in prod; falls to FRONTEND_URL; dev is permissive)
# If neither CORS_ORIGINS nor FRONTEND_URL is set in production, all origins are rejected (fail-closed).
CORS_ORIGINS=""

# Redis (optional)
REDIS_URL="redis://localhost:6379"

# Mercado Pago (optional)
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""

# Email (optional)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Webhook Security — email webhook signature validation (fail-closed: webhooks rejected if not configured)
# SendGrid: ECDSA public key from SendGrid dashboard > Settings > Mail Settings > Event Webhook > Signature
SENDGRID_WEBHOOK_VERIFICATION_KEY=""
# Resend: webhook signing secret from Resend dashboard > Webhooks (format: whsec_...)
RESEND_WEBHOOK_SECRET=""

# Sentry (optional)
SENTRY_DSN=""

# PostHog (product analytics — opcional). Sem POSTHOG_KEY, os eventos são no-op.
# Eventos backend (user_logged_in, user_registered) usam grupo por tenant.
POSTHOG_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"

# WhatsApp (Meta Cloud API) — versão do Graph API (versões são depreciadas).
# Default v21.0; ajuste aqui quando precisar migrar de versão.
WHATSAPP_GRAPH_VERSION="v21.0"

# AI drafts (Vercel AI SDK — opcional). Claude-first: prefira anthropic.
# AI_PROVIDER: "anthropic" | "openai". AI_API_KEY: chave do provider. AI_MODEL: opcional.
# Fallback: se AI_PROVIDER/AI_API_KEY vazios, usa ANTHROPIC_API_KEY (anthropic) ou OPENAI_API_KEY (openai).
AI_PROVIDER=""
AI_API_KEY=""
AI_MODEL=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Encryption key for sensitive data at rest (2FA secrets, email/WhatsApp configs)
# Must be a strong secret string (any length — derived to 32 bytes via SHA-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Billing Jobs (optional)
ENABLE_BILLING_JOBS="false"

# Automation Engine (optional — requires Redis)
ENABLE_AUTOMATION_ENGINE="false"

# Backup Job (optional — runs pg_dump daily)
ENABLE_BACKUP_JOB="false"
BACKUP_DIR="/tmp/vyd-backups"
# S3/R2 upload (optional — if set, backups are uploaded and local copy removed)
BACKUP_S3_BUCKET=""
BACKUP_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Scheduled Reports (optional — sends report notifications by email)
ENABLE_SCHEDULED_REPORTS="false"
