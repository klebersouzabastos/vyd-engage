# Database
DATABASE_URL="postgresql://flowcrm:flowcrm_dev_password@localhost:5432/flowcrm"

# JWT Secrets
JWT_SECRET="your-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Logging — pino level: trace|debug|info|warn|error|fatal (default: debug in dev, info in prod)
LOG_LEVEL=""

# Queue dashboard (Bull Board) — Basic-Auth credentials. Both must be set to mount /admin/queues.
QUEUE_DASHBOARD_USER=""
QUEUE_DASHBOARD_PASS=""

# CORS — comma-separated allowed origins (falls back to FRONTEND_URL in production, permissive in dev)
CORS_ORIGINS=""

# Redis (optional)
REDIS_URL="redis://localhost:6379"

# Mercado Pago (optional)
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""

# Email (optional)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Webhook Security (optional — if set, email webhooks require this secret in x-webhook-secret header)
EMAIL_WEBHOOK_SECRET=""

# Sentry (optional)
SENTRY_DSN=""

# AI drafts (Vercel AI SDK — opcional). Claude-first: prefira anthropic.
# AI_PROVIDER: "anthropic" | "openai". AI_API_KEY: chave do provider. AI_MODEL: opcional.
# Fallback: se AI_PROVIDER/AI_API_KEY vazios, usa ANTHROPIC_API_KEY (anthropic) ou OPENAI_API_KEY (openai).
AI_PROVIDER=""
AI_API_KEY=""
AI_MODEL=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Encryption key for sensitive data at rest (2FA secrets, email/WhatsApp configs)
# Must be a strong secret string (any length — derived to 32 bytes via SHA-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Billing Jobs (optional)
ENABLE_BILLING_JOBS="false"
