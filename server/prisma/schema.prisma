// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

// NOTE: o ERD generator (prisma-erd-generator) foi REMOVIDO do caminho de deploy.
// O Railway roda `./node_modules/.bin/prisma generate` direto (sem node_modules/.bin
// no PATH), e o Prisma não conseguia spawnar o binário do generator → ENOENT → build
// falhava. docs/database/ERD.md é um snapshot; para regenerar, re-adicione este bloco
// temporariamente e rode `npx prisma generate` (npx põe .bin no PATH). Nunca no deploy.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION & AUTHORIZATION
// ============================================

enum UserRole {
  ADMIN
  USER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String
  phone        String?
  avatar       String?
  role         UserRole   @default(USER)
  status       UserStatus @default(PENDING)

  // Super-admin da plataforma (cross-tenant). O papel por tenant continua em `role`.
  isPlatformAdmin Boolean @default(false)

  // Tenant relationship
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Email verification
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?

  // Password reset
  passwordResetToken   String?
  passwordResetExpires DateTime?

  // 2FA (optional)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  refreshTokens         RefreshToken[]
  invitations           Invitation[]          @relation("InvitedBy")
  assignedLeads         Lead[]                @relation("LeadAssignment")
  assignedDeals         Deal[]                @relation("DealAssignment")
  assignedTasks         Task[]                @relation("TaskAssignment")
  interactions          Interaction[]         @relation("InteractionUser")
  notifications         Notification[]        @relation("NotificationUser")
  reports               Report[]              @relation("ReportCreator")
  calendarConnections   CalendarConnection[]  @relation("UserCalendarConnections")
  savedViews            SavedView[]
  suggestions           Suggestion[]          @relation("SuggestionAuthor")
  meetingAvailabilities MeetingAvailability[]
  auditLogs             AuditLog[]
  goals                 Goal[]

  @@index([email])
  @@index([tenantId])
  @@index([tenantId, email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  role      UserRole @default(USER)
  token     String   @unique
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy String
  inviter   User     @relation("InvitedBy", fields: [invitedBy], references: [id])
  accepted  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([tenantId])
  @@index([email])
  @@index([invitedBy])
}

// ============================================
// TENANT / ORGANIZATION
// ============================================

model Tenant {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  logo     String?
  settings Json    @default("{}")

  // Subscription
  subscription Subscription?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users                 User[]
  invitations           Invitation[]
  leads                 Lead[]
  companies             Company[]
  tasks                 Task[]
  automations           Automation[]
  tags                  Tag[]
  customFields          CustomField[]
  whatsappConnections   WhatsAppConnection[]
  emailConfigs          EmailConfig[]
  payments              Payment[]
  apiKeys               ApiKey[]
  webhooks              Webhook[]
  notifications         Notification[]
  interactions          Interaction[]
  funnels               Funnel[]
  scoreRules            ScoreRule[]
  reports               Report[]
  deals                 Deal[]
  calendarConnections   CalendarConnection[]
  savedViews            SavedView[]
  suggestions           Suggestion[]
  emailTemplates        EmailTemplate[]
  meetingAvailabilities MeetingAvailability[]
  auditLogs             AuditLog[]
  staleDays             Int                    @default(5)
  products              Product[]
  goals                 Goal[]
  stageTaskTemplates    StageTaskTemplate[]
  importBatches         ImportBatch[]
  campaigns             Campaign[]
  deepResearches        DeepResearch[]
  deepResearchTemplates DeepResearchTemplate[]
  empreendimentos       Empreendimento[]
  commercialRoadmaps    CommercialRoadmap[]
  playbookTemplates     PlaybookTemplate[]

  @@index([slug])
}

// ============================================
// SUBSCRIPTION & BILLING
// ============================================

enum PlanType {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PaymentMethod {
  CREDIT_CARD
  PIX
  BOLETO
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

model Plan {
  id          String   @id @default(uuid())
  type        PlanType @unique
  name        String
  price       Decimal  @db.Decimal(10, 2)
  description String?
  features    Json // Store plan features as JSON
  limits      Json // Store plan limits as JSON
  highlighted Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id       String             @id @default(uuid())
  tenantId String             @unique
  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId   String
  plan     Plan               @relation(fields: [planId], references: [id])
  status   SubscriptionStatus @default(TRIAL)

  // Billing
  billingCycle BillingCycle @default(MONTHLY)
  startDate    DateTime     @default(now())
  renewalDate  DateTime
  cancelledAt  DateTime?
  trialEndsAt  DateTime?

  // Payment method
  paymentMethod Json? // Store payment method details

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  payments Payment[]

  @@index([tenantId])
  @@index([status])
  @@index([planId])
}

model Payment {
  id             String        @id @default(uuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  // Payment details
  amount   Decimal       @db.Decimal(10, 2)
  currency String        @default("BRL")
  method   PaymentMethod
  status   PaymentStatus @default(PENDING)

  // Mercado Pago
  mercadoPagoId           String?
  mercadoPagoPreferenceId String?
  mercadoPagoStatus       String?

  // Payment data (encrypted)
  paymentData Json?

  // Invoice
  invoiceUrl    String?
  invoiceNumber String?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  paidAt    DateTime?

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
  @@index([mercadoPagoId])
}

// ============================================
// PIPELINE / FUNNELS
// ============================================

enum FunnelType {
  LEAD
  DEAL
}

model Funnel {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  type      FunnelType @default(LEAD)
  isDefault Boolean    @default(false)
  order     Int        @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  columns FunnelColumn[]
  deals   Deal[]

  @@unique([tenantId, name, type])
  @@index([tenantId])
  @@index([tenantId, isDefault])
  @@index([tenantId, type])
}

model FunnelColumn {
  id       String @id @default(uuid())
  funnelId String
  funnel   Funnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  title     String
  color     String  @default("#3B82F6")
  order     Int     @default(0)
  isDefault Boolean @default(false) // "novo" column cannot be deleted

  // Maps to LeadStatus for backend sync
  mappedStatus LeadStatus?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  leads              Lead[]              @relation("LeadFunnelColumn")
  deals              Deal[]              @relation("DealFunnelColumn")
  stageTaskTemplates StageTaskTemplate[]

  @@index([funnelId])
  @@index([funnelId, order])
}

// ============================================
// LEAD SCORING
// ============================================

enum ScoreEvent {
  LEAD_CREATED
  STATUS_CHANGED
  TAG_ADDED
  INTERACTION_CREATED
  EMAIL_OPENED
  EMAIL_CLICKED
  WHATSAPP_REPLIED
  FORM_SUBMITTED
}

model ScoreRule {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  eventType   ScoreEvent
  points      Int
  description String?
  active      Boolean    @default(true)
  conditions  Json? // Optional conditions (e.g., specific tag, specific status)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, eventType])
  @@index([tenantId, active])
}

// ============================================
// COMPANIES
// ============================================

enum CompanySize {
  MICRO
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

model Company {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  fantasyName String? // Nome fantasia (name = razão social)
  cnpj        String?
  domain      String?
  industry    String?
  size        CompanySize?
  phone       String?
  address     String?
  website     String?
  notes       String?

  // External identifier from a source system (e.g. legacy CRM export) — used as
  // the primary idempotency key when importing companies.
  externalId String?

  // Custom fields (JSON for flexibility) — mirrors Lead/Deal.
  customFields Json @default("{}")

  // Import Pro — batch this record was created by (for history + rollback).
  importBatchId String?

  // Soft delete
  deletedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  leads              Lead[]
  deals              Deal[]
  interactions       Interaction[]
  tasks              Task[]
  empreendimentos    Empreendimento[]
  commercialRoadmaps CommercialRoadmap[]
  deepResearches     DeepResearch[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, domain])
  @@index([tenantId, deletedAt])
  @@index([tenantId, externalId])
  @@index([tenantId, importBatchId])
}

// ============================================
// DEALS
// ============================================

enum DealStage {
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSING
  WON
  LOST
}

model Deal {
  id                String          @id @default(uuid())
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name              String
  value             Decimal         @db.Decimal(12, 2)
  stage             DealStage       @default(QUALIFICATION)
  probability       Int             @default(20)
  expectedCloseDate DateTime?
  leadId            String?
  lead              Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  companyId         String?
  company           Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  empreendimentoId  String?
  empreendimento    Empreendimento? @relation(fields: [empreendimentoId], references: [id], onDelete: SetNull)
  assignedTo        String?
  assignedUser      User?           @relation("DealAssignment", fields: [assignedTo], references: [id], onDelete: SetNull)
  notes             String?
  customFields      Json            @default("{}")
  lostReason        String?
  lostCompetitor    String?

  // Pipeline position
  funnelId         String?
  funnel           Funnel?       @relation(fields: [funnelId], references: [id], onDelete: SetNull)
  funnelColumnId   String?
  funnelColumn     FunnelColumn? @relation("DealFunnelColumn", fields: [funnelColumnId], references: [id], onDelete: SetNull)
  positionInColumn Int           @default(0)

  // Import Pro — batch this record was created by (for history + rollback)
  importBatchId String?

  // AI Sales Assistant — close-propensity score (0-100), generated by AI
  aiScore          Float?
  aiScoreUpdatedAt DateTime?
  aiScoreFactors   Json?

  // Soft delete
  deletedAt DateTime?

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  closedAt           DateTime?
  interactions       Interaction[]
  tasks              Task[]
  stageHistory       DealStageHistory[]
  dealProducts       DealProduct[]
  commercialRoadmaps CommercialRoadmap[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, empreendimentoId])
  @@index([tenantId, assignedTo])
  @@index([tenantId, leadId])
  @@index([tenantId, companyId])
  @@index([tenantId, expectedCloseDate])
  @@index([tenantId, funnelId])
  @@index([funnelColumnId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, importBatchId])
}

// ============================================
// LEADS & CRM
// ============================================

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  SOCIAL_MEDIA
  REFERRAL
  EMAIL
  PHONE
  OTHER
}

model Lead {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Basic info
  name       String
  email      String?
  phone      String?
  company    String?
  position   String?
  companyId  String?
  companyRef Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Desdobramento comercial — organograma de decisores + vínculo a empreendimento
  reportsToId      String?
  reportsTo        Lead?           @relation("LeadHierarchy", fields: [reportsToId], references: [id], onDelete: SetNull)
  directReports    Lead[]          @relation("LeadHierarchy")
  empreendimentoId String?
  empreendimento   Empreendimento? @relation(fields: [empreendimentoId], references: [id], onDelete: SetNull)

  // Contact conversion
  isContact   Boolean   @default(false)
  convertedAt DateTime?

  // Status & Source
  status LeadStatus @default(NEW)
  source LeadSource @default(WEBSITE)
  score  Int        @default(0)

  // Email marketing opt-out (LGPD) — excluded from all current/future campaigns
  unsubscribed   Boolean   @default(false)
  unsubscribedAt DateTime?

  // Custom fields (JSON for flexibility)
  customFields Json @default("{}")

  // Metadata
  notes        String?
  assignedTo   String?
  assignedUser User?   @relation("LeadAssignment", fields: [assignedTo], references: [id], onDelete: SetNull)

  // Pipeline position
  funnelColumnId   String?
  funnelColumn     FunnelColumn? @relation("LeadFunnelColumn", fields: [funnelColumnId], references: [id], onDelete: SetNull)
  positionInColumn Int           @default(0)

  // Import Pro — batch this record was created by (for history + rollback)
  importBatchId String?

  // Soft delete
  deletedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tags                LeadTag[]
  interactions        Interaction[]
  tasks               Task[]
  automationLogs      AutomationLog[]
  deals               Deal[]
  campaignRecipients  CampaignRecipient[]
  roadmapStakeholders RoadmapStakeholder[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, email])
  @@index([tenantId, empreendimentoId])
  @@index([reportsToId])
  @@index([tenantId, createdAt])
  @@index([funnelColumnId])
  @@index([tenantId, isContact])
  @@index([tenantId, companyId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, importBatchId])
  @@index([tenantId, unsubscribed])
}

model Tag {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#2563EB")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads LeadTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model LeadTag {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([leadId, tagId])
  @@index([leadId])
  @@index([tagId])
}

model CustomField {
  id        String          @id @default(uuid())
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  type      CustomFieldType
  options   Json? // For select type
  required  Boolean         @default(false)
  order     Int             @default(0)
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ============================================
// TASKS
// ============================================

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)

  // Assignment
  assignedTo   String?
  assignedUser User?    @relation("TaskAssignment", fields: [assignedTo], references: [id], onDelete: SetNull)
  leadId       String?
  lead         Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  dealId       String?
  deal         Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Desdobramento comercial — tipo de ação de acesso + vínculo a empreendimento/roadmap
  type             TaskType?
  empreendimentoId String?
  empreendimento   Empreendimento?    @relation(fields: [empreendimentoId], references: [id], onDelete: SetNull)
  roadmapId        String?
  roadmap          CommercialRoadmap? @relation(fields: [roadmapId], references: [id], onDelete: SetNull)

  // Dates
  dueDate     DateTime?
  completedAt DateTime?

  // Google Calendar sync
  googleEventId String?

  // Soft delete
  deletedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedTo])
  @@index([tenantId, dueDate])
  @@index([tenantId, deletedAt])
  @@index([tenantId, companyId])
  @@index([tenantId, empreendimentoId])
  @@index([tenantId, roadmapId])
  @@index([tenantId, type])
}

// ============================================
// CALENDAR INTEGRATIONS
// ============================================

enum CalendarProvider {
  GOOGLE
}

model CalendarConnection {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation("UserCalendarConnections", fields: [userId], references: [id], onDelete: Cascade)

  provider     CalendarProvider @default(GOOGLE)
  accessToken  String
  refreshToken String
  email        String
  calendarId   String           @default("primary")
  syncEnabled  Boolean          @default(true)
  lastSyncAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, provider])
  @@index([tenantId])
  @@index([userId])
}

// ============================================
// AUTOMATIONS
// ============================================

enum AutomationStatus {
  ACTIVE
  PAUSED
  DRAFT
}

enum AutomationLogStatus {
  SUCCESS
  ERROR
  SKIPPED
  WAITING
  CANCELLED
}

enum AutomationStepType {
  DELAY
  UPDATE_LEAD
  ADD_TAG
  REMOVE_TAG
  CONDITION
  SEND_WHATSAPP
  SEND_EMAIL
}

model Automation {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  status      AutomationStatus @default(DRAFT)
  trigger     Json // Store trigger configuration
  steps       Json // Store automation steps
  conditions  Json? // Store conditions
  flowData    Json? // Store visual builder node/edge data

  // Statistics
  runsCount    Int @default(0)
  successCount Int @default(0)
  errorCount   Int @default(0)

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastRunAt DateTime?

  // Relations
  logs         AutomationLog[]
  interactions Interaction[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model AutomationLog {
  id           String     @id @default(uuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  status  AutomationLogStatus
  message String?
  data    Json?
  error   String?

  // Structured fields (previously buried in JSON `data`)
  leadId      String?
  lead        Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  stepOrder   Int?
  stepType    AutomationStepType?
  executionId String?
  executeAt   DateTime?

  createdAt DateTime @default(now())

  @@index([automationId])
  @@index([createdAt])
  @@index([leadId])
  @@index([executionId])
  @@index([status])
}

// ============================================
// COMMUNICATIONS
// ============================================

enum InteractionType {
  EMAIL
  WHATSAPP
  CALL
  MEETING
  NOTE
  STATUS_CHANGE
  AUTOMATION
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  TEXTAREA
  CHECKBOX
}

enum WebhookLogStatus {
  SUCCESS
  FAILED
  PENDING
}

enum WhatsAppProvider {
  OFFICIAL_API
  EVOLUTION_API
  BAILEYS
  WPPCONNECT
  CHATAPI
}

enum WhatsAppConnectionStatus {
  CONNECTED
  DISCONNECTED
  CONNECTING
  ERROR
}

model WhatsAppConnection {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String
  provider WhatsAppProvider
  status   WhatsAppConnectionStatus @default(DISCONNECTED)

  // Configuration (encrypted)
  config Json

  // QR Code (temporary)
  qrCode          String?
  qrCodeExpiresAt DateTime?

  // Statistics
  messagesSent     Int @default(0)
  messagesReceived Int @default(0)

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastConnectedAt DateTime?

  @@index([tenantId])
  @@index([tenantId, status])
}

enum EmailProvider {
  SMTP
  SENDGRID
  MAILGUN
  SES
  RESEND
}

model EmailConfig {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  provider  EmailProvider
  fromEmail String
  fromName  String?

  // Configuration (encrypted)
  config Json

  // Status
  verified   Boolean   @default(false)
  verifiedAt DateTime?

  // Statistics
  emailsSent Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Interaction {
  id       String  @id @default(uuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId   String?
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  type      InteractionType
  direction InteractionDirection
  subject   String?
  content   String
  metadata  Json?

  // Related entities
  automationId String?
  automation   Automation? @relation(fields: [automationId], references: [id], onDelete: SetNull)
  userId       String?
  user         User?       @relation("InteractionUser", fields: [userId], references: [id], onDelete: SetNull)
  dealId       String?
  deal         Deal?       @relation(fields: [dealId], references: [id], onDelete: SetNull)
  companyId    String?
  company      Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Import Pro — batch this record was created by (for history + rollback)
  importBatchId String?

  // Soft delete — used by Import Pro rollback (interactions are otherwise append-only)
  deletedAt DateTime?

  /// Append-only: interactions are immutable communication records
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, leadId])
  @@index([tenantId, dealId])
  @@index([tenantId, companyId])
  @@index([tenantId, createdAt])
  @@index([tenantId, type])
  @@index([tenantId, importBatchId])
}

// ============================================
// API & WEBHOOKS
// ============================================

model ApiKey {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name       String
  key        String    @unique
  keyHash    String // Hashed version for verification
  scopes     String[]  @default([]) // Granular permission scopes (empty = full access, backward compat)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  active     Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([keyHash])
}

model Webhook {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  url    String
  events String[] // Array of event types
  secret String // Secret for webhook signature
  active Boolean  @default(true)

  // Statistics
  successCount    Int       @default(0)
  failureCount    Int       @default(0)
  lastTriggeredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  logs WebhookLog[]

  @@index([tenantId])
  @@index([tenantId, active])
}

model WebhookLog {
  id        String  @id @default(uuid())
  webhookId String
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  event      String
  status     WebhookLogStatus @default(PENDING)
  statusCode Int?
  durationMs Int? // Delivery duration in milliseconds (req 14)
  success    Boolean? // Delivery success indicator (req 14)
  response   String?
  error      String?
  attempts   Int              @default(1)

  createdAt DateTime @default(now())

  @@index([webhookId])
  @@index([createdAt])
}

// ============================================
// NOTIFICATIONS
// ============================================

enum NotificationType {
  TASK_DUE
  TASK_OVERDUE
  LEAD_ASSIGNED
  AUTOMATION_ERROR
  PAYMENT_FAILED
  SUBSCRIPTION_EXPIRING
  DEAL_AT_RISK
  SYSTEM
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

model Notification {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)

  type     NotificationType
  title    String
  message  String
  status   NotificationStatus @default(UNREAD)
  link     String?
  metadata Json?

