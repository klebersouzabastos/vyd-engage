// ============================================
// EMAIL CAMPAIGNS
// ============================================

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

enum CampaignRecipientStatus {
  PENDING
  SENT
  OPENED
  CLICKED
  UNSUBSCRIBED
  BOUNCED
  ERROR
}

enum CampaignEventType {
  OPENED
  CLICKED
  BOUNCED
  UNSUBSCRIBED
}

model Campaign {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name   String
  status CampaignStatus @default(DRAFT)

  // Sender
  fromName  String?
  fromEmail String?
  // Email config (provider) used to send — references EmailConfig.id
  configId  String?

  // Content
  subject String @default("")
  // Body as Block[] (text|image|button|divider|spacer) — see shared contract
  blocks  Json   @default("[]")

  // Audience segmentation filters (status/tag/responsavel/source/score/lastInteraction/no-interaction)
  audienceFilters Json @default("{}")

  // Scheduling
  scheduledAt DateTime?
  sentAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipients CampaignRecipient[]
  events     CampaignEvent[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tenantId   String
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Public token for open/click/unsubscribe tracking (unique per recipient)
  token String @unique

  // Denormalized recipient identity (snapshot at send time)
  email String
  name  String?

  status CampaignRecipientStatus @default(PENDING)

  // Per-recipient delivery bookkeeping (edge case: max 3 retries)
  errorCount Int       @default(0)
  lastError  String?
  sentAt     DateTime?
  openedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events CampaignEvent[]

  @@unique([campaignId, leadId])
  @@index([campaignId])
  @@index([tenantId])
  @@index([campaignId, status])
  @@map("campaign_recipients")
}

model CampaignEvent {
  id          String            @id @default(uuid())
  campaignId  String
  campaign    Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   CampaignRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  tenantId    String
  leadId      String

  type CampaignEventType
  // Original URL for CLICKED events
  url  String?

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([campaignId, type])
  @@index([recipientId])
  @@index([campaignId, type, createdAt])
  @@map("campaign_events")
}

// ============================================
// DEEP RESEARCH (Pesquisa Profunda)
//
// Paste-in flow (v1): o usuário edita um prompt-modelo, roda no ChatGPT
// (Deep Research) manualmente e cola o markdown de volta, que é renderizado
// como um site estilizado no frontend. `status`/`reportMeta` já preveem a
// futura integração assíncrona com a OpenAI Deep Research API.
// ============================================

enum DeepResearchStatus {
  DRAFT // criada; prompt sendo montado; sem markdown ainda
  RESEARCHING // (futuro) job da API rodando; em v1 = aguardando colar resultado
  COMPLETED // markdown colado/recebido e renderizável
  FAILED // (futuro) job da API falhou
}

model DeepResearchTemplate {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String // "Empresa", "Segmento"
  description String?
  // Corpo do prompt com placeholders no formato [EMPRESA]
  promptBody  String

  // Template semente (não deletável pela UI); re-seed idempotente
  isBuiltin   Boolean @default(false)
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  researches DeepResearch[]

  @@index([tenantId])
  @@index([tenantId, isBuiltin])
  @@map("deep_research_templates")
}

model DeepResearch {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdById String?
  title       String

  // Desdobramento comercial — empresa-alvo (opcional, para semear um roadmap)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Template de origem (snapshot do prompt final fica em promptUsed)
  templateId String?
  template   DeepResearchTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  // Prompt final com placeholders resolvidos + valores preenchidos
  promptUsed String @default("")
  variables  Json   @default("{}") // { "EMPRESA": "ACME" }

  status DeepResearchStatus @default(DRAFT)

  // Markdown bruto colado do ChatGPT (já limpo de marcadores no save)
  reportMarkdown String?
  // { sources: string[], generatedAt?: string, charCount?: number }
  reportMeta     Json?

  // Integração com a OpenAI Deep Research API (modo background)
  providerResponseId String? // id do response da OpenAI
  providerError      String?
  requestedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commercialRoadmaps CommercialRoadmap[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([status, providerResponseId])
  @@index([tenantId, companyId])
  @@map("deep_research")
}

// ============================================
// DESDOBRAMENTO COMERCIAL
// ============================================

enum TaskType {
  VISITA
  APRESENTACAO
  LIGACAO
  REUNIAO
  EMAIL
  PROPOSTA
  OUTRO
}

enum CommercialRoadmapStatus {
  PLANEJAMENTO
  EM_ANDAMENTO
  PROPOSTA
  GANHO
  PERDIDO
  ARQUIVADO
}

enum StakeholderRole {
  DECISOR
  INFLUENCIADOR
  TECNICO
  APROVADOR
  USUARIO
}

enum StakeholderPosture {
  FAVORAVEL
  NEUTRO
  CONTRARIO
  DESCONHECIDO
}

model Empreendimento {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Sempre vinculado a uma empresa (cliente)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name                 String
  type                 String? // obra, expansão, planta, licitação...
  location             String?
  estimatedValue       Decimal?  @db.Decimal(14, 2)
  phase                String? // estudo, projeto, licitação, execução...
  expectedDecisionDate DateTime?
  status               String    @default("ATIVO") // ATIVO | STANDBY | ENCERRADO
  notes                String?
  customFields         Json      @default("{}")
  createdById          String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  contacts Lead[]
  deals    Deal[]
  tasks    Task[]
  roadmaps CommercialRoadmap[]

  @@index([tenantId])
  @@index([tenantId, companyId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@map("empreendimentos")
}

model PlaybookTemplate {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isBuiltin   Boolean @default(false)
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps    PlaybookStep[]
  roadmaps CommercialRoadmap[]

  @@index([tenantId])
  @@index([tenantId, isBuiltin])
  @@map("playbook_templates")
}

model PlaybookStep {
  id         String           @id @default(uuid())
  templateId String
  template   PlaybookTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  order       Int
  title       String
  actionType  TaskType         @default(OUTRO)
  targetRole  StakeholderRole?
  offsetDays  Int              @default(0)
  priority    TaskPriority     @default(MEDIUM)
  description String?

  @@index([templateId])
  @@map("playbook_steps")
}

model CommercialRoadmap {
  id          String  @id @default(uuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById String?

  title String

  // Sempre por empresa; opcionalmente por empreendimento. companyId usa Restrict
  // para não destruir o roadmap em um hard-delete de empresa (o app usa soft-delete).
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  empreendimentoId String?
  empreendimento   Empreendimento? @relation(fields: [empreendimentoId], references: [id], onDelete: SetNull)

  // Funil + semente (pesquisa) + playbook usado
  dealId             String?
  deal               Deal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  deepResearchId     String?
  deepResearch       DeepResearch?     @relation(fields: [deepResearchId], references: [id], onDelete: SetNull)
  playbookTemplateId String?
  playbookTemplate   PlaybookTemplate? @relation(fields: [playbookTemplateId], references: [id], onDelete: SetNull)

  status             CommercialRoadmapStatus @default(PLANEJAMENTO)
  targetProposalDate DateTime?
  notes              String?
  customFields       Json                    @default("{}")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  stakeholders RoadmapStakeholder[]
  tasks        Task[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, companyId])
  @@index([tenantId, empreendimentoId])
  @@index([tenantId, deletedAt])
  @@map("commercial_roadmaps")
}

model RoadmapStakeholder {
  id        String            @id @default(uuid())
  roadmapId String
  roadmap   CommercialRoadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  leadId    String
  lead      Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)

  roleInDecision StakeholderRole    @default(USUARIO)
  posture        StakeholderPosture @default(DESCONHECIDO)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roadmapId, leadId])
  @@index([roadmapId])
  @@index([leadId])
  @@map("roadmap_stakeholders")
}

model Suggestion {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation("SuggestionAuthor", fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  route       String?
  type        SuggestionType   @default(IMPROVEMENT)
  status      SuggestionStatus @default(PENDING)
  adminNotes  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  resolvedAt  DateTime?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, userId])
  @@index([tenantId, createdAt])
}

enum SuggestionType {
  IMPROVEMENT
  BUG
}

enum SuggestionStatus {
  PENDING
  IN_REVIEW
  IN_PROGRESS
  DONE
  REJECTED
}
